# ══════════════════════════════════════════════════════════════════════════════
# MetodoBase — Variables de entorno
# Copia este archivo como .env y completa los valores.
# NUNCA commitear .env con secrets reales.
# ══════════════════════════════════════════════════════════════════════════════

# ═════════════════════════════════════════════════════════════
# OBLIGATORIAS EN PRODUCCIÓN (el servidor NO arranca sin estas)
# ═════════════════════════════════════════════════════════════
# SECRET_KEY: Generar con: openssl rand -hex 32 (mínimo 32 caracteres)
# LICENSE_SALT: Generar con: openssl rand -hex 16 (mínimo 16 caracteres)
# DATABASE_URL: PostgreSQL connection string
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET: De Stripe Dashboard
# STRIPE_PRICE_STANDARD/GYM_COMERCIAL/CLINICA: Price IDs de productos en Stripe

# ── Entorno ──────────────────────────────────────────────────────────────────
# "development" (default) | "production"
ENVIRONMENT=development
METODOBASE_ENV=development

# ── Auth — Secret Key (OBLIGATORIO en producción) ───────────────────────────
# Genera uno con: openssl rand -hex 32
# IMPORTANTE: Mínimo 32 caracteres
SECRET_KEY=
# Legacy compatibility (use SECRET_KEY instead):
# WEB_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS — Orígenes permitidos (separados por coma) ─────────────────────────
# En producción: solo tu dominio real. Ejemplo: https://app.metodobase.mx
CORS_ORIGINS=http://localhost:8000,http://localhost:8001

# ── Base de datos (SQLAlchemy) ───────────────────────────────────────────────
# Dejar vacío para usar SQLite local (desarrollo).
# En producción (Railway/Docker): postgresql://user:password@host:5432/metodobase
DATABASE_URL=

# ── Base de datos legacy (desktop) ──────────────────────────────────────────
# Dejar vacío para usar SQLite por defecto (~/.local/share/MetodoBase/)
DB_PATH=

# ── Directorio de datos (Docker/Railway) ─────────────────────────────────────
# Override para todo el directorio de datos (BD, planes, config)
# En Docker: /data
METODOBASE_DATA_DIR=

# ── Stripe (Pagos) ──────────────────────────────────────────────────────────
# OBLIGATORIO en producción
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (obtener del Stripe Dashboard > Products)
# Moneda: MXN. Crear Products con precios en pesos mexicanos.
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_GYM_COMERCIAL=
STRIPE_PRICE_CLINICA=
STRIPE_PRICE_PRO_USUARIO=

# Stripe Payment Links (Stripe Dashboard > Payment Links — URLs pre-construidas)
# Formato: https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_STANDARD=
STRIPE_PAYMENT_LINK_GYM_COMERCIAL=
STRIPE_PAYMENT_LINK_CLINICA=
STRIPE_PAYMENT_LINK_PRO_USUARIO=

# ── MercadoPago (Pagos LATAM) ───────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Licencias — Salt (OBLIGATORIO en producción) ────────────────────────────
# Genera uno con: openssl rand -hex 16
# IMPORTANTE: Mínimo 16 caracteres
LICENSE_SALT=
# Legacy compatibility (use LICENSE_SALT instead):
# METODO_BASE_SALT=

# ── Servidor ─────────────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8001
# URL base pública (OBLIGATORIO en producción — NO puede ser localhost)
# Ejemplo: https://app.metodobase.mx
BASE_URL=http://localhost:8000

# ── Email transaccional (Resend.com) ────────────────────────────────────────
RESEND_API_KEY=

# ── Google OAuth (Login con Google) ─────────────────────────────────────────
# Obtener de Google Cloud Console > APIs & Services > Credentials
# Crear "OAuth 2.0 Client ID" tipo "Aplicación web"
# Agregar http://localhost:8000 en "Orígenes autorizados de JavaScript"
GOOGLE_CLIENT_ID=

# ── Migración de BD (Feature Flags) ─────────────────────────────────────────
# Fase 1 (default): Legacy es primary
# Fase 2: Dual-write a ambas BDs
# Fase 3: SQLAlchemy es primary
# Fase 4: Legacy deprecated
# En producción usar DB_MIGRATION_PHASE=4 (SQLAlchemy only)
DB_MIGRATION_PHASE=
DB_DUAL_WRITE=false
DB_USE_SA_READ=false
DB_SA_PRIMARY=false
DB_LEGACY_DEPRECATED=false

# ── Métricas y Monitoreo ────────────────────────────────────────────────────
# Sentry DSN para error tracking (OBLIGATORIO en producción)
# Obtener de sentry.io > Settings > Client Keys (DSN)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Habilitar recolección de métricas de latencia
METRICS_ENABLED=true
# Cantidad de requests a mantener en histórico para percentiles
METRICS_HISTORY_SIZE=1000

# ── Alertas ─────────────────────────────────────────────────────────────────
# Habilitar sistema de alertas
ALERT_ENABLED=true
# Minutos de cooldown entre alertas repetidas
ALERT_COOLDOWN_MINUTES=5
# Webhook de Slack para alertas (opcional)
ALERT_SLACK_WEBHOOK=
# Email para alertas (usa RESEND_API_KEY si está configurado)
ALERT_EMAIL_TO=
# Webhook HTTP genérico para alertas (opcional)
ALERT_WEBHOOK_URL=

# ── Rate Limiting ───────────────────────────────────────────────────────────
# Requests por minuto por cliente (default: 60)
RATE_LIMIT_RPM=60
# Burst size permitido (default: 10)
RATE_LIMIT_BURST=10
DB_SHADOW_WRITE=true
DB_DEBUG_SYNC=false
DB_SYNC_TIMEOUT=30
DB_SYNC_RETRIES=3
DB_MIGRATION_BATCH=100

# ── Demo seed (solo desarrollo) ─────────────────────────────────────────────
# Poner 1 para crear usuarios demo al iniciar (gym@test.com / test123)
METODOBASE_SEED_DEMO=1

# ── Docs API ─────────────────────────────────────────────────────────────────
# En producción los docs están deshabilitados. Para forzar: ENABLE_DOCS=1
ENABLE_DOCS=

# ── Agent Pipeline (OpenAI) ─────────────────────────────────────────────────
# Required for the multi-agent orchestration pipeline (node run.js)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
